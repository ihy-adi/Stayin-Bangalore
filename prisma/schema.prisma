generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SEEKER
  OWNER
  ADMIN
}

enum PropertyType {
  PG
  APARTMENT
  FLAT
  ROOM
  HOSTEL
  CO_LIVING
  SERVICE_APARTMENT
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  REJECTED
  ARCHIVED
}

enum FurnishingType {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum RoomType {
  PRIVATE
  SHARED
  SINGLE
  DOUBLE_SHARING
  TRIPLE_SHARING
  FOUR_SHARING
  ONE_BHK
  TWO_BHK
  THREE_BHK
  STUDIO
}

enum GenderPreference {
  ANY
  MALE
  FEMALE
  FAMILY
}

enum MediaType {
  IMAGE
  VIDEO
}

enum DiscussionType {
  QUESTION
  FEEDBACK
  TIP
  WARNING
  FLATMATE
  GENERAL
}

enum ContentStatus {
  VISIBLE
  HIDDEN
  REMOVED
  PENDING_REVIEW
}

enum VoteType {
  UP
  DOWN
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
  RESOLVED
}

enum ReportTargetType {
  PROPERTY
  THREAD
  COMMENT
  REVIEW
  USER
}

enum VisitStatus {
  LIVED_THERE
  VISITED
  CONTACTED
  NOT_VISITED
}

// ─── NextAuth required models (keep for PrismaAdapter + Google OAuth) ─────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core models ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  emailVerified DateTime?
  // image is used by NextAuth (Google profile photo). avatarUrl is user-uploaded.
  image        String?
  avatarUrl    String?
  passwordHash String?
  phone        String?
  role         UserRole @default(SEEKER)
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts           Account[]
  sessions           Session[]
  ownedProperties    Property[]         @relation("PropertyOwner")
  savedProperties    SavedProperty[]
  reviews            Review[]
  discussionThreads  DiscussionThread[]
  discussionComments DiscussionComment[]
  threadVotes        ThreadVote[]
  commentVotes       CommentVote[]
  reportsMade        Report[]           @relation("ReportsMade")
  reportsReviewed    Report[]           @relation("ReportsReviewed")
  flatmatePosts      FlatmatePost[]
  propertyViews      PropertyView[]
  inquiries          Inquiry[]

  @@index([role])
  @@index([isVerified])
}

model Property {
  id      String @id @default(uuid())
  ownerId String
  owner   User   @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  title        String
  slug         String        @unique
  description  String?       @db.Text
  propertyType PropertyType
  status       ListingStatus @default(DRAFT)

  addressLine1 String?
  addressLine2 String?
  area         String
  city         String        @default("Bangalore")
  state        String        @default("Karnataka")
  pincode      String?

  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  rentAmount     Int
  depositAmount  Int?
  maintenanceFee Int?

  roomType         RoomType?
  furnishing       FurnishingType?
  genderPreference GenderPreference @default(ANY)

  hasAc            Boolean?
  foodIncluded     Boolean?
  hasWifi          Boolean?
  hasPowerBackup   Boolean?
  hasParking       Boolean?
  hasLaundry       Boolean?
  hasSecurity      Boolean?
  attachedBathroom Boolean?

  lockInMonths     Int?
  noticePeriodDays Int?
  availableFrom    DateTime?
  isAvailable      Boolean   @default(true)

  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  verifiedById String?

  sourceUrl       String?
  sourceName      String?
  scrapedAt       DateTime?
  extraAttributes Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media             PropertyMedia[]
  amenities         PropertyAmenity[]
  savedBy           SavedProperty[]
  reviews           Review[]
  discussionThreads DiscussionThread[]
  flatmatePosts     FlatmatePost[]
  views             PropertyView[]
  inquiries         Inquiry[]

  @@index([ownerId])
  @@index([propertyType])
  @@index([status])
  @@index([area])
  @@index([city])
  @@index([rentAmount])
  @@index([isVerified])
  @@index([latitude, longitude])
}

model PropertyMedia {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  mediaType MediaType
  url       String
  caption   String?
  sortOrder Int       @default(0)
  isPrimary Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([mediaType])
}

model Amenity {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String?
  createdAt DateTime @default(now())

  properties PropertyAmenity[]
}

model PropertyAmenity {
  propertyId String
  amenityId  String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity  Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([propertyId, amenityId])
  @@index([amenityId])
}

model SavedProperty {
  id         String @id @default(uuid())
  userId     String
  propertyId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([propertyId])
}

model Review {
  id         String @id @default(uuid())
  userId     String
  propertyId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  rating         Int
  title          String?
  content        String?       @db.Text
  visitStatus    VisitStatus   @default(NOT_VISITED)
  wouldRecommend Boolean?

  cleanlinessRating   Int?
  safetyRating        Int?
  foodRating          Int?
  valueForMoneyRating Int?

  status ContentStatus @default(VISIBLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@index([rating])
  @@index([status])
}

// ─── Discussion system ────────────────────────────────────────────────────────

model DiscussionThread {
  id         String @id @default(uuid())
  propertyId String
  authorId   String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  type    DiscussionType
  title   String?
  content String         @db.Text

  status   ContentStatus @default(VISIBLE)
  isPinned Boolean       @default(false)

  upvoteCount   Int @default(0)
  downvoteCount Int @default(0)
  commentCount  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments DiscussionComment[]
  votes    ThreadVote[]

  @@index([propertyId])
  @@index([authorId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model DiscussionComment {
  id              String  @id @default(uuid())
  threadId        String
  authorId        String
  parentCommentId String?

  thread        DiscussionThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author        User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment DiscussionComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       DiscussionComment[] @relation("CommentReplies")

  content String        @db.Text
  status  ContentStatus @default(VISIBLE)

  upvoteCount   Int @default(0)
  downvoteCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes CommentVote[]

  @@index([threadId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([status])
  @@index([createdAt])
}

model ThreadVote {
  id       String   @id @default(uuid())
  threadId String
  userId   String
  voteType VoteType

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([threadId, userId])
  @@index([userId])
  @@index([voteType])
}

model CommentVote {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  voteType  VoteType

  comment DiscussionComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([commentId, userId])
  @@index([userId])
  @@index([voteType])
}

// ─── Supporting models ────────────────────────────────────────────────────────

model FlatmatePost {
  id         String  @id @default(uuid())
  userId     String
  propertyId String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  title           String
  description     String           @db.Text
  preferredGender GenderPreference?
  budgetShare     Int?
  moveInDate      DateTime?
  contactMethod   String?
  status          ContentStatus @default(VISIBLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([propertyId])
  @@index([status])
}

model PropertyView {
  id         String  @id @default(uuid())
  propertyId String
  userId     String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  viewedAt DateTime @default(now())

  @@index([propertyId])
  @@index([userId])
  @@index([viewedAt])
}

model Inquiry {
  id         String @id @default(uuid())
  propertyId String
  userId     String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  message String? @db.Text
  status  String  @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([userId])
  @@index([status])
}

model Report {
  id           String  @id @default(uuid())
  reporterId   String
  reviewedById String?

  reporter   User  @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReportsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  targetType ReportTargetType
  targetId   String

  reason    String
  status    ReportStatus @default(PENDING)
  adminNote String?      @db.Text

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@index([reporterId])
  @@index([reviewedById])
  @@index([targetType, targetId])
  @@index([status])
}
